# =============================================================================
# Playto Payout Engine — environment variables
# =============================================================================
#
# Two intended use cases:
#
#   1. LOCAL DEV  → copy this file to `backend/.env`. Defaults below match
#                   docker-compose.yml (Postgres on :5433, Redis on :6380),
#                   so a fresh clone runs end-to-end with:
#                       docker compose up -d
#                       cd backend && python manage.py migrate && python manage.py seed
#                       python manage.py runserver
#
#   2. PRODUCTION → paste each variable into your platform's env vars dashboard
#                   (Render → Environment, Railway → Variables, etc.). Use the
#                   "PRODUCTION" notes next to each var. DO NOT commit a real
#                   `.env` for prod — `.env` is in .gitignore for a reason.
#
# Generate a real DJANGO_SECRET_KEY before deploying:
#   python -c "import secrets; print(secrets.token_urlsafe(50))"
#
# =============================================================================


# -----------------------------------------------------------------------------
# Django core
# -----------------------------------------------------------------------------

# 50+ char random string. The default below is fine for local dev; production
# MUST override with a real random value (see command above).
DJANGO_SECRET_KEY=dev-only-secret-do-not-use-in-prod

# DEBUG=true in dev (verbose tracebacks, no security middleware).
# DEBUG=false in production — flips on the SECURE_* hardening block in settings.py
# (HSTS, secure cookies, SSL redirect, etc.). Always false on Render/Railway.
DJANGO_DEBUG=true

# Comma-separated list of allowed Host headers.
# LOCAL DEV:    "*" (allow anything)
# PRODUCTION:   the exact deploy hostname, e.g. "playto-payout.onrender.com"
#               (no scheme, no trailing slash)
DJANGO_ALLOWED_HOSTS=*

# Comma-separated origins trusted for CSRF (Django admin, browser-driven POSTs).
# LOCAL DEV:    leave empty
# PRODUCTION:   "https://playto-payout.onrender.com" (WITH scheme, unlike ALLOWED_HOSTS)
DJANGO_CSRF_TRUSTED_ORIGINS=


# -----------------------------------------------------------------------------
# Database — Postgres
# -----------------------------------------------------------------------------
#
# Two configuration paths, in priority order:
#
#   A. DATABASE_URL  → preferred for hosted deploys. dj-database-url parses the
#                      URL, decodes URL-encoded passwords, preserves
#                      ?sslmode=require query strings. Use this on Render
#                      (Neon connection string), Railway (auto-injected), Fly,
#                      Supabase, etc.
#
#   B. POSTGRES_*    → individual fields for local dev. Used only when
#                      DATABASE_URL is unset. Defaults below match
#                      docker-compose.yml.
#
# Set EITHER A OR B, not both. If DATABASE_URL is non-empty, the POSTGRES_*
# fields below are ignored.
# -----------------------------------------------------------------------------

# PRODUCTION (Neon, Railway Postgres, RDS, etc.):
# DATABASE_URL=postgresql://user:pass@host.neon.tech/playto_pay?sslmode=require

# LOCAL DEV (matches docker-compose.yml):
POSTGRES_DB=playto_pay
POSTGRES_USER=playto
POSTGRES_PASSWORD=playto
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5433

# Per-request connection lifetime in seconds. 0 = close after each request.
# Rationale lives in playto_pay/settings.py:113-119 (worker fan-out vs
# Postgres max_connections).  Keep at 0 unless you put PgBouncer in front.
POSTGRES_CONN_MAX_AGE=0


# -----------------------------------------------------------------------------
# Celery — Redis broker + result backend
# -----------------------------------------------------------------------------
#
# Both URLs point at the same Redis instance, but use different logical DBs
# (/0 = broker queue, /1 = task results) so namespaces don't collide.
#
# LOCAL DEV:    redis://127.0.0.1:6380/<n>  (matches docker-compose.yml)
# PRODUCTION:   the rediss:// URL from Upstash / Railway Redis / ElastiCache.
#               Upstash gives you a single URL — use it for both broker and
#               result backend; the path /0 vs /1 just keys keys differently.
# -----------------------------------------------------------------------------

CELERY_BROKER_URL=redis://127.0.0.1:6380/0
CELERY_RESULT_BACKEND=redis://127.0.0.1:6380/1

# Production examples (uncomment and adapt):
# CELERY_BROKER_URL=rediss://default:<password>@<host>.upstash.io:6379/0
# CELERY_RESULT_BACKEND=rediss://default:<password>@<host>.upstash.io:6379/1

# Hard / soft per-task time limits (seconds). The soft limit raises
# SoftTimeLimitExceeded which our task can clean up; the hard limit kills the
# worker process. Defaults are conservative — bump if real bank API calls are slow.
CELERY_TASK_TIME_LIMIT=60
CELERY_TASK_SOFT_TIME_LIMIT=50


# -----------------------------------------------------------------------------
# Domain knobs — rarely changed
# -----------------------------------------------------------------------------

# How long a payout can sit in PROCESSING before the retry sweeper picks it up.
PAYOUT_PROCESSING_TIMEOUT_SECONDS=30

# Max retry attempts before a stuck payout transitions to FAILED + refund.
PAYOUT_MAX_RETRIES=3

# Idempotency-Key TTL. The cleanup task deletes rows older than this.
IDEMPOTENCY_KEY_TTL_HOURS=24

# Bank simulation probabilities. Must satisfy: success + failure <= 1.0.
# Remainder (default 0.10) is the "hang" probability. Validated at app boot
# in payouts/apps.py:ready.
BANK_SIMULATION_SUCCESS=0.70
BANK_SIMULATION_FAILURE=0.20


# -----------------------------------------------------------------------------
# CORS
# -----------------------------------------------------------------------------
#
# LOCAL DEV:    leave CORS_ALLOW_ALL_ORIGINS=true so the Vite dev server on
#               :5173 can hit the backend on :8000.
#
# PRODUCTION:   single-origin deploy (frontend served by Django + WhiteNoise)
#               needs no CORS at all — set CORS_ALLOW_ALL_ORIGINS=false and
#               leave CORS_ALLOWED_ORIGINS empty. Only set CORS_ALLOWED_ORIGINS
#               if you split frontend onto a separate origin (Vercel etc.).
# -----------------------------------------------------------------------------

CORS_ALLOW_ALL_ORIGINS=true
CORS_ALLOWED_ORIGINS=
