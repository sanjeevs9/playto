DJANGO_SECRET_KEY=replace-me-in-prod
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=*
DJANGO_CSRF_TRUSTED_ORIGINS=

# Defaults match docker-compose.yml so a fresh clone runs end-to-end with
# `docker compose up -d && python manage.py migrate`.
POSTGRES_DB=playto_pay
POSTGRES_USER=playto
POSTGRES_PASSWORD=playto
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5433
POSTGRES_CONN_MAX_AGE=0
# Or, instead of POSTGRES_*, set:
# DATABASE_URL=postgres://user:pass@host:5432/dbname

CELERY_BROKER_URL=redis://127.0.0.1:6380/0
CELERY_RESULT_BACKEND=redis://127.0.0.1:6380/1

PAYOUT_PROCESSING_TIMEOUT_SECONDS=30
PAYOUT_MAX_RETRIES=3
IDEMPOTENCY_KEY_TTL_HOURS=24
BANK_SIMULATION_SUCCESS=0.70
BANK_SIMULATION_FAILURE=0.20

CORS_ALLOW_ALL_ORIGINS=true
CORS_ALLOWED_ORIGINS=
